{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Detailed personal and lifestyle information for matchmaking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "fullName": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "age": { "type": "number" },
        "location": { "type": "string" },
        "bio": { "type": "string" },
        "lifestyle": { "type": "object" },
        "social": { "type": "object" },
        "privacySettings": { "type": "object" },
        "hasGuardian": { "type": "boolean" },
        "guardianId": { "type": "string" },
        "assessmentCompleted": { "type": "boolean" }
      },
      "required": ["uid", "fullName", "gender", "age"]
    },
    "AssessmentResult": {
      "title": "Assessment Result",
      "description": "Results of the personality and marriage readiness tests.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "personalityType": { "type": "string" },
        "valuesScore": { "type": "number" },
        "readinessScore": { "type": "number" },
        "analysis": { "type": "string" }
      },
      "required": ["uid", "personalityType", "readinessScore"]
    },
    "Match": {
      "title": "Match",
      "description": "Compatibility pairing between two users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user1Id": { "type": "string" },
        "user2Id": { "type": "string" },
        "compatibilityScore": { "type": "number" },
        "reasoning": { "type": "string" },
        "status": { "type": "string", "enum": ["suggested", "pending_approval", "approved", "rejected"] }
      },
      "required": ["id", "user1Id", "user2Id", "compatibilityScore"]
    },
    "TrainingProgress": {
      "title": "Training Progress",
      "description": "Tracking user progress through educational modules.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "completedModules": { "type": "array", "items": { "type": "string" } },
        "quizScores": { "type": "object", "description": "Map of moduleId to score" }
      },
      "required": ["uid", "completedModules"]
    },
    "Guardian": {
      "title": "Guardian",
      "description": "Information about a user's guardian (Wali).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "wardId": { "type": "string", "description": "The UID of the female user" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "relation": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "wardId", "fullName", "phone", "relation"]
    },
    "InteractionRequest": {
      "title": "Interaction Request",
      "description": "Formal request from a male user to a female user's guardian.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "guardianId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_guardian", "pending_receiver", "approved", "rejected"] },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "receiverId", "guardianId", "status"]
    }
  },
  "firestore": {
    "/profiles/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/assessments/{uid}": {
      "schema": "AssessmentResult",
      "description": "User assessment results."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Match records."
    },
    "/training/{uid}": {
      "schema": "TrainingProgress",
      "description": "User training progress records."
    },
    "/guardians/{guardianId}": {
      "schema": "Guardian",
      "description": "Guardian information."
    },
    "/requests/{requestId}": {
      "schema": "InteractionRequest",
      "description": "Formal interaction requests."
    }
  }
}
