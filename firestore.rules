rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Profiles: Users can read/write their own profile. 
    // Others can only read masked profiles if they are suggested matches (complex logic simplified for MVP).
    match /profiles/{uid} {
      allow read: if isAuthenticated(); // In production, this should be more restricted
      allow create, update: if isOwner(uid);
    }

    // Assessments: Only the owner can read/write their own assessment.
    match /assessments/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Training: Only the owner can read/write their own training progress.
    match /training/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Matches: Users can read matches they are part of.
    match /matches/{matchId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.user1Id || request.auth.uid == resource.data.user2Id);
      allow create: if isAuthenticated(); // Usually created by a system process/admin
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
